FROM alpine:3.18
RUN apk --no-cache add ca-certificates curl docker-cli

WORKDIR /app

ARG SERVICE
# Copy pre-compiled binary from host
COPY bin/${SERVICE} ./service-bin

# Copy static frontend resources (needed by gateway, harmless for others) and test payloads
COPY frontend/ ./frontend/
COPY test_payloads/ ./test_payloads/

ENTRYPOINT ["./service-bin"]
