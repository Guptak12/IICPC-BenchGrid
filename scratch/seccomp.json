{
    "defaultAction": "SCMP_ACT_ALLOW",
    "syscalls": [
        {
            "names": ["fork", "vfork"],
            "action": "SCMP_ACT_KILL_PROCESS"
        },
        {
            "names": [
                "connect",
                "socketpair"
            ],
            "action": "SCMP_ACT_ERRNO"
        },
        {
            "names": [
                "ptrace",
                "personality",
                "setuid", "setgid",
                "setreuid", "setregid",
                "setresuid", "setresgid",
                "mount", "umount2",
                "pivot_root", "chroot",
                "syslog",
                "kexec_load", "kexec_file_load",
                "create_module", "init_module",
                "finit_module", "delete_module",
                "iopl", "ioperm"
            ],
            "action": "SCMP_ACT_ERRNO"
        }
    ]
}
