# Multi-stage build to prepare a standard directory with permissions
FROM debian:bookworm-slim AS build
RUN mkdir -p /usr/src && chmod 777 /usr/src

# Final secure runtime sandbox using Google Distroless for C++
FROM gcr.io/distroless/cc-debian12

# Copy the prepared directory
COPY --from=build --chown=root:root /usr/src /usr/src

# Set working directory to matches our workspace expectation
WORKDIR /usr/src
EXPOSE 8080
